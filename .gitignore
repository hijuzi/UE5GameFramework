# ============================================
# Unreal Engine 5 Project - Git Ignore
# ============================================

# --------------------------------------------
# Visual Studio / IDE
# --------------------------------------------
.vs/
.vscode/
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.idea/

# --------------------------------------------
# UE5 Generated / Build Artifacts
# --------------------------------------------
Binaries/
DerivedDataCache/
Intermediate/
Saved/
Build/
Windows/

# --------------------------------------------
# Content (keep only source assets, ignore cooked)
# --------------------------------------------
# Uncomment if you want to ignore cooked content
# *_BuiltData.uasset

# Ignored content folders
GameFrameworkDev/Content/Orasot_Bundle/
GameFrameworkDev/PSOCache/

# --------------------------------------------
# Platform Specific
# --------------------------------------------
*.xcodeproj
*.xcworkspace

# --------------------------------------------
# OS generated files
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --------------------------------------------
# Misc
# --------------------------------------------
*.log
*.tmp
*.swp
*.pdb
*.exp
*.obj
*.pyc
__pycache__/

# --------------------------------------------
# UE5PSOPackager - 仅忽略构建产物，保留源码
# --------------------------------------------
UE5PSOPackager/dist/
UE5PSOPackager/build/
UE5PSOPackager/*.spec
